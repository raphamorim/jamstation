    spuGaussRow(s, 416, 0x493A, 0x498A, 0x49D9, 0x4A29, 0x4A77, 0x4AC5, 0x4B13, 0x4B5F);
    spuGaussRow(s, 424, 0x4BAC, 0x4BF7, 0x4C42, 0x4C8D, 0x4CD7, 0x4D20, 0x4D68, 0x4DB0);
    spuGaussRow(s, 432, 0x4DF7, 0x4E3E, 0x4E84, 0x4EC9, 0x4F0E, 0x4F52, 0x4F95, 0x4FD7);
    spuGaussRow(s, 440, 0x5019, 0x505A, 0x509A, 0x50DA, 0x5118, 0x5156, 0x5194, 0x51D0);
    spuGaussRow(s, 448, 0x520C, 0x5247, 0x5281, 0x52BA, 0x52F3, 0x532A, 0x5361, 0x5397);
    spuGaussRow(s, 456, 0x53CC, 0x5401, 0x5434, 0x5467, 0x5499, 0x54CA, 0x54FA, 0x5529);
    spuGaussRow(s, 464, 0x5558, 0x5585, 0x55B2, 0x55DE, 0x5609, 0x5632, 0x565B, 0x5684);
    spuGaussRow(s, 472, 0x56AB, 0x56D1, 0x56F6, 0x571B, 0x573E, 0x5761, 0x5782, 0x57A3);
    spuGaussRow(s, 480, 0x57C3, 0x57E2, 0x57FF, 0x581C, 0x5838, 0x5853, 0x586D, 0x5886);
    spuGaussRow(s, 488, 0x589E, 0x58B5, 0x58CB, 0x58E0, 0x58F4, 0x5907, 0x5919, 0x592A);
    spuGaussRow(s, 496, 0x593A, 0x5949, 0x5958, 0x5965, 0x5971, 0x597C, 0x5986, 0x598F);
    spuGaussRow(s, 504, 0x5997, 0x599E, 0x59A4, 0x59A9, 0x59AD, 0x59B0, 0x59B2, 0x59B3);
}

// NOTE: the SDL audio callback (psone_audio_cb) lives in sdl.jam now.
// The SPU is clocked CPU-synchronously from runOneFrame (one sample
// per 768 cycles) for deterministic envelope state; those samples are
// pushed into an SPSC ring buffer that the callback drains. The SPU
// has no audio-thread coupling anymore.
